# Anthropic
ANTHROPIC_API_KEY=your_key_here

# Data store — choose one
USE_SQLITE=true          # true = SQLite (easy local dev), false = InfluxDB
SQLITE_PATH=data/sensors.db

# InfluxDB (only needed if USE_SQLITE=false)
INFLUXDB_URL=http://localhost:8086
INFLUXDB_TOKEN=your_token_here
INFLUXDB_ORG=asset_health
INFLUXDB_BUCKET=sensors

# MCP server ports
SENSOR_MCP_PORT=8001
CMMS_MCP_PORT=8002
INVENTORY_MCP_PORT=8003
SCHEDULING_MCP_PORT=8004
NOTIFY_MCP_PORT=8005

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
venv/
env/
ENV/
*.egg-info/

# Environment variables (NEVER commit this — contains API keys)
.env

# Generated data — these are reproducible from generate_sensor_data.py
data/sensors.db
data/sensors.db-wal
data/sensors.db-shm
data/*.csv

# MCP server generated databases (mock CMMS/inventory/scheduling state + alert log)
mcp_servers/*.db
mcp_servers/alerts.log

# Agent run traces (generated output, not source)
agent/traces/

# Streamlit local config (telemetry/headless settings — machine-specific)
.streamlit/

# AWS deployment build artifacts — all regenerable via the package.py /
# package_model.py scripts; none of these should be committed since
# they're large, environment-specific binary outputs, not source.
aws/lambda/_build/
aws/lambda/_staging/
aws/lambda/package.zip
aws/eventbridge/_build/
aws/eventbridge/_staging/
aws/eventbridge/orchestrator_package.zip
aws/sagemaker/_staging/
aws/sagemaker/model.tar.gz

# Trained model weights (large binary — see README for whether to keep these)
# Comment the next two lines out if you DO want to commit the trained model
# models/saved/*.pt

# Pytest
.pytest_cache/
.coverage
htmlcov/

# OS
.DS_Store
Thumbs.db

# IDE
.vscode/
.idea/
*.swp
